# --- Data lake (datos generados, NO versionar) ---
# Ignora el contenido pero conserva la estructura de carpetas vía .gitkeep
data/**
!data/**/
!data/**/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Entorno virtual / uv ---
.venv/
venv/
.env
.python-version

# --- Jupyter ---
.ipynb_checkpoints/

# --- Herramientas / caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- IDE ---
.vscode/
.idea/

# --- Sistema operativo ---
.DS_Store
Thumbs.db
